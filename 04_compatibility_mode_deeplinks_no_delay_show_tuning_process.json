{
    "name": "Deep Links - Compatibility Mode - Show Tuning Process",
    "author": "ADBTuner",
    "version": "1.0.4",
    "description": "Load content via deep link URLs (where supported) and starts the stream immediately (doesn't attempt to hide the tuning process). Adds workarounds to help support apps that don't behave as expected. This should only be used if the default doesn't work correctly.",
    "uuid": "e002c6b1-db1f-4e44-88f0-e2ceaed194d5",
    "global_options": {
        "wait_for_video_playback_detection": false,
        "use_fixed_delay": true,
        "fixed_delay_seconds": 1,
        "wait_after_post_playback_start_commands_seconds": 0
    },
    "pre_tune_commands": [
        "input keyevent KEYCODE_MEDIA_STOP",
        "am force-stop '||TARGET_PACKAGE_NAME||'",
        "sleep 2"
    ],
    "tune_commands": [
        "am start -W -a android.intent.action.VIEW -d '||TARGET_URL_OR_IDENTIFIER||' '||TARGET_PACKAGE_NAME||'"
    ],
    "tune_match_text_commands": [
        {
            "match_text": [
                "who's watching",
                "choose an account",
                "edit profiles"
            ],
            "commands": [
                "input keyevent KEYCODE_DPAD_CENTER"
            ],
            "start_checking_after_seconds": 5
        }
    ],
    "post_playback_start_commands": [],
    "post_tune_commands": [
        "am force-stop '||TARGET_PACKAGE_NAME||'",
        "input keyevent KEYCODE_HOME"
    ],
    "timed_keep_active_commands": []
}